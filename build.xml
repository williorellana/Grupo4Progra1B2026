<?xml version="1.0" encoding="UTF-8"?>
<project name="ZooAurora" default="run" basedir=".">
    <description>Sistema de Gestión del Zoológico La Aurora</description>
    <target name="compile">
        <mkdir dir="build/classes"/>
        <javac srcdir="src" destdir="build/classes" encoding="UTF-8" includeantruntime="false"/>
    </target>
    <target name="run" depends="compile">
        <java classname="zoologico.Main" classpath="build/classes" fork="true"/>
    </target>
    <target name="clean">
        <delete dir="build"/>
    </target>
</project>
